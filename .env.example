# =============================================================================
# FluxGrid ERP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Backend: Database ---
# PostgreSQL connection string (REQUIRED)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=fluxgrid;Username=postgres;Password=your-db-password

# --- Backend: JWT ---
# JWT signing secret key - at least 32 characters (REQUIRED)
Jwt__SecretKey=your-jwt-secret-key-min-32-chars-long
# JWT issuer (optional, defaults to "FluxGrid")
Jwt__Issuer=FluxGrid
# JWT audience (optional, defaults to "FluxGrid")
Jwt__Audience=FluxGrid
# JWT token expiry in minutes (optional, defaults to 60)
Jwt__ExpiryMinutes=60

# --- Backend: Hosting ---
# Backend URL (optional, defaults to http://localhost:5020)
ASPNETCORE_URLS=http://localhost:5020

# --- Backend: Seed ---
# Seed admin password (optional). If not set, a random password is generated and logged on first startup.
SEED_ADMIN_PASSWORD=your-seed-admin-password

# --- Frontend ---
# Backend API URL used by the frontend
NEXT_PUBLIC_API_URL=http://localhost:5020
